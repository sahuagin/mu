/target
/Cargo.lock.dev
**/*.rs.bk
.idea/
.vscode/
*.swp
.DS_Store

# local development scratch
/scratch/
/tmp/
*.local.toml
.env
.env.local

# Python bytecode cache (scripts/ has a few .py tools, e.g. the
# compaction probe harness). A stale scripts/__pycache__/*.pyc predates
# this rule and stays tracked; this just stops NEW ones being added.
__pycache__/
*.pyc

# code_index per-project DB (we use mu's own caches if wired in)
/.code_index/

# delegation workspaces — each delegation runs in an isolated jj
# workspace under here; not part of the source tree.
/.delegations/

# archived wake-up summaries; current MORNING.md is committed for review.
/MORNING-*.md

# core dumps (from crashes of related binaries run in this dir)
*.core

# Goal-session briefings live OUTSIDE the public repo (~/mu-briefings/).
# History was rewritten 2026-06-04 to remove them; never re-add.
MORNING*.md

# br doctor per-run artifacts
.doctor/

# python venvs (maturin develop, etc.)
.venv/
__pycache__/
*.pyc

# local beads mirror — central beadsd is canonical
.beads/
