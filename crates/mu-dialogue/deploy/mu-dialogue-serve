#!/bin/sh
# mu-dialogue-serve — wrapper the rc.d service execs (mirrors
# code-index-mcp-serve). Resolves the release binary from the mu checkout and
# passes the bind address through; the binary reads DATABASE_PATH /
# MU_DIALOGUE_ALLOWED_HOSTS from the environment the rc.d service sets.
#
# Install: install -m 0555 mu-dialogue-serve ~/.local/bin/mu-dialogue-serve
set -eu

: "${HOME:=/home/tcovert}"
BIN="${MU_DIALOGUE_BIN:-$HOME/src/public_github/mu/target/release/mu-dialogue}"
: "${LISTEN:=0.0.0.0:7740}"

if [ ! -x "$BIN" ]; then
    printf 'mu-dialogue-serve: binary not found or not executable: %s\n' "$BIN" >&2
    printf '  build it: (cd ~/src/public_github/mu && TMPDIR=$HOME/tmp cargo build --release -p mu-dialogue)\n' >&2
    exit 1
fi

# DATABASE_PATH (default ~/.local/share/agent.sqlite) and
# MU_DIALOGUE_ALLOWED_HOSTS are read from the environment by the binary.
exec "$BIN" --listen "$LISTEN"
