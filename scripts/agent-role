#!/bin/sh
# agent-role — resolve a role's ranked dispatch target(s) from agent_roles.toml.
#
# One config names the provider:model hierarchy for each role, so scripts
# (ci-aipr, goal-protocol workers, …) ask for a ROLE and a RANK instead of
# hardcoding a model. Change the model for a role in one place.
#
# Usage:
#   agent-role <role>              every rank, one per line: "<provider> <model>"
#   agent-role <role> <rank>       one rank (0-based):       "<provider> <model>"
#   agent-role --max-turns <role> [<rank>]
#                                 resolved turn budget(s), one per rank;
#                                 blank/omitted = let mu use provider defaults,
#                                 0 = explicitly uncapped
#   agent-role --cmd <role> [<rank>]   a ready-to-run dispatch command:
#                                        claude-oauth  → `claude -p --model <m>`   (Max sub, ToS-clean)
#                                        otherwise     → `mu ask --bare --provider <p> --model <m>`
#
# Resolution: `tq -o json <role>.ranked` emits the ranked array as JSON; `jq`
# indexes it. Per-model params come from ~/.config/mu/models.toml via mu's
# id-match at dispatch — not from here. Role dispatch params such as `max_turns`
# live here because they describe seat behavior, not model capability.
set -eu

ROLES="${AGENT_ROLES:-$HOME/.config/mu/agent_roles.toml}"
TQ="${TQ:-$HOME/.cargo/bin/tq}"
command -v "$TQ" >/dev/null 2>&1 || TQ=tq

die() { printf 'agent-role: %s\n' "$1" >&2; exit 1; }

CMD=0
MAX_TURNS_MODE=0
while [ "${1:-}" ]; do
    case "$1" in
        --cmd) CMD=1; shift ;;
        --max-turns) MAX_TURNS_MODE=1; shift ;;
        --) shift; break ;;
        -*) die "unknown option: $1" ;;
        *) break ;;
    esac
done
[ "$CMD" -eq 1 ] && [ "$MAX_TURNS_MODE" -eq 1 ] && die "--cmd and --max-turns are mutually exclusive"
ROLE="${1:-}"; RANK="${2:-}"

emit() {  # $1=provider $2=model
    if [ "$CMD" -eq 1 ]; then
        case "$1" in
            claude-oauth) printf 'claude -p --model %s\n' "$2" ;;
            *)            printf 'mu ask --bare --provider %s --model %s\n' "$1" "$2" ;;
        esac
    else
        printf '%s %s\n' "$1" "$2"
    fi
}

# Explicit-model OVERRIDE — the escape hatch so a special-case caller can pin a
# model WITHOUT hardcoding the dispatch and bypassing the router entirely. Set
# AGENT_ROLE_PIN="<model>" (provider inferred) or "<provider> <model>" (explicit);
# agent-role emits THAT target, skipping the ranking + the roles file. Still routes
# through emit() so the dispatch-path map (claude-oauth -> claude -p) and future
# per-model params apply. Role/rank args are ignored when pinned. Inference covers
# the common cases; pass the explicit two-token form for anything it guesses wrong.
# For --max-turns with a pin, AGENT_ROLE_PIN_MAX_TURNS is the only source; blank
# means "no explicit turn budget".
if [ -n "${AGENT_ROLE_PIN:-}" ]; then
    if [ "$MAX_TURNS_MODE" -eq 1 ]; then
        [ -n "${AGENT_ROLE_PIN_MAX_TURNS:-}" ] && printf '%s\n' "$AGENT_ROLE_PIN_MAX_TURNS"
        exit 0
    fi
    # shellcheck disable=SC2086
    set -- $AGENT_ROLE_PIN
    if [ "$#" -ge 2 ]; then
        emit "$1" "$2"
    else
        case "$1" in
            */*)                            pp=openrouter ;;    # vendor/model
            claude-*)                       pp=claude-oauth ;;  # claude-opus-4-8, claude-sonnet-4-6
            gpt-oss*|*:*|qwen*|gemma*|glm*) pp=ollama ;;        # local tags (model:tag, gpt-oss, ...)
            gpt-*|o[0-9]*|codex*)           pp=openai-codex ;;  # gpt-5.5, o-series
            *)                              pp=ollama ;;
        esac
        emit "$pp" "$1"
    fi
    exit 0
fi

[ -n "$ROLE" ] || die "usage: agent-role [--cmd|--max-turns] <role> [<rank>]"
[ -f "$ROLES" ] || die "no roles file: $ROLES (set AGENT_ROLES to override)"

json=$("$TQ" -o json -f "$ROLES" "$ROLE.ranked" 2>/dev/null) \
    || die "role '$ROLE' not found in $ROLES"
role_max_turns=$("$TQ" -o json -f "$ROLES" "$ROLE.max_turns" 2>/dev/null || printf 'null')
case "$role_max_turns" in ''|null) role_max_turns=null ;; esac

# Lease-aware (LOTO): if this role has a provider=ollama target and the shared
# ollama box is held by ANOTHER owner, sink ollama targets to the bottom of the
# ranked list so rank-0 becomes a usable non-ollama fallback. Probes only when an
# ollama target exists; fail-open (etcd down -> --held non-zero -> no reorder);
# opt out with AGENT_ROLE_NO_LEASE=1.
if [ -z "${AGENT_ROLE_NO_LEASE:-}" ] \
    && printf '%s' "$json" | jq -e 'any(.[]; .provider=="ollama")' >/dev/null 2>&1 \
    && command -v with-ollama-lease >/dev/null 2>&1 \
    && with-ollama-lease --held >/dev/null 2>&1; then
    json=$(printf '%s' "$json" | jq 'to_entries|sort_by([(.value.provider=="ollama"),.key])|map(.value)')
fi

emit_max_turns() {  # $1=rank
    printf '%s' "$json" | jq -r --argjson role_max "$role_max_turns" ".[$1].max_turns // \$role_max // \"\""
}

if [ -n "$RANK" ]; then
    p=$(printf '%s' "$json" | jq -r ".[$RANK].provider // empty")
    m=$(printf '%s' "$json" | jq -r ".[$RANK].model // empty")
    [ -n "$p" ] && [ -n "$m" ] || die "role '$ROLE' has no rank $RANK"
    if [ "$MAX_TURNS_MODE" -eq 1 ]; then
        emit_max_turns "$RANK"
    else
        emit "$p" "$m"
    fi
else
    n=$(printf '%s' "$json" | jq -r 'length')
    i=0
    while [ "$i" -lt "$n" ]; do
        if [ "$MAX_TURNS_MODE" -eq 1 ]; then
            emit_max_turns "$i"
        else
            p=$(printf '%s' "$json" | jq -r ".[$i].provider")
            m=$(printf '%s' "$json" | jq -r ".[$i].model")
            emit "$p" "$m"
        fi
        i=$((i + 1))
    done
fi
