#!/bin/sh
# mu-spawn — launch a non-POT worker agent.
#
# Current contract (mu-ktj0): POTs/jails are gone. This wrapper is the small,
# boring dispatch surface used by mu's spawn_worker path and by humans who want
# an ad-hoc child agent. It selects a provider/model through scripts/agent-role
# (unless explicitly overridden), then runs either:
#   - claude -p              for provider=claude-oauth
#   - mu ask --bare          for all other providers
#
# Usage:
#   mu-spawn [options] [prompt...]
#   echo "task" | mu-spawn --session-id session-9 --daemon-id d1
#
# Options:
#   --role ROLE          agent_roles.toml role to resolve (default: coding)
#   --rank N            role rank, 0-based (default: 0)
#   --provider P        provider override (skips role provider)
#   --model M           model override (skips role model)
#   --session-id ID     spawned worker session id (default: env MU_SESSION_ID)
#   --daemon-id ID      daemon id for dialogue identity (default: env MU_DAEMON_ID)
#   --reply-to ID       parent session id (default: env MU_REPLY_TO)
#   --cwd DIR           working directory for the child (default: cwd)
#   --timeout SECS      wall-clock timeout (default: env MU_SPAWN_TIMEOUT or 3600)
#   --mcp-config FILE   claude MCP config file (default: env MU_SPAWN_MCP_CONFIG)
#   --dry-run           print the resolved command and exit
#   -h, --help          show this help
#
# Prompt is read from argv when present, otherwise stdin. The child is told its
# mcp-dialogue peer id, which is mu:<daemon_id>:<session_id> when both pieces are
# known. mu-native sessions bind dialogue_say/dialogue_poll identity in the tool
# layer; claude workers get this as prompt guidance and can use an MCP config if
# supplied.
set -eu

usage() { sed -n '2,39p' "$0" | sed 's/^# \{0,1\}//'; }
die() { printf 'mu-spawn: %s\n' "$1" >&2; exit 2; }
q() { printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\''/g")"; }

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
AGENT_ROLE=${AGENT_ROLE:-$SCRIPT_DIR/agent-role}
ROLE=coding
RANK=0
PROVIDER=${MU_SPAWN_PROVIDER:-}
MODEL=${MU_SPAWN_MODEL:-}
SESSION_ID=${MU_SESSION_ID:-}
DAEMON_ID=${MU_DAEMON_ID:-}
REPLY_TO=${MU_REPLY_TO:-}
CWD=$(pwd)
TIMEOUT_SECS=${MU_SPAWN_TIMEOUT:-3600}
MCP_CONFIG=${MU_SPAWN_MCP_CONFIG:-}
MU_BIN=${MU:-mu}
DRY_RUN=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --role) ROLE=${2:?--role needs a value}; shift 2 ;;
    --rank) RANK=${2:?--rank needs a value}; shift 2 ;;
    --provider) PROVIDER=${2:?--provider needs a value}; shift 2 ;;
    --model) MODEL=${2:?--model needs a value}; shift 2 ;;
    --session-id) SESSION_ID=${2:?--session-id needs a value}; shift 2 ;;
    --daemon-id) DAEMON_ID=${2:?--daemon-id needs a value}; shift 2 ;;
    --reply-to) REPLY_TO=${2:?--reply-to needs a value}; shift 2 ;;
    --cwd) CWD=${2:?--cwd needs a value}; shift 2 ;;
    --timeout) TIMEOUT_SECS=${2:?--timeout needs a value}; shift 2 ;;
    --mcp-config) MCP_CONFIG=${2:?--mcp-config needs a value}; shift 2 ;;
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --) shift; break ;;
    -*) die "unknown option: $1" ;;
    *) break ;;
  esac
done

if [ -z "$PROVIDER" ] || [ -z "$MODEL" ]; then
  [ -x "$AGENT_ROLE" ] || die "agent-role not executable at $AGENT_ROLE"
  role_line=$($AGENT_ROLE "$ROLE" "$RANK") || exit $?
  role_provider=$(printf '%s
' "$role_line" | awk 'NR==1 {print $1}')
  role_model=$(printf '%s
' "$role_line" | awk 'NR==1 {$1=""; sub(/^ /, ""); print}')
  [ -n "$role_provider" ] && [ -n "$role_model" ] || die "agent-role returned no provider/model for $ROLE rank $RANK"
  [ -n "$PROVIDER" ] || PROVIDER=$role_provider
  [ -n "$MODEL" ] || MODEL=$role_model
fi

PROMPT_FILE=$(mktemp "${TMPDIR:-/tmp}/mu-spawn.prompt.XXXXXX")
SYS_FILE=$(mktemp "${TMPDIR:-/tmp}/mu-spawn.system.XXXXXX")
trap 'rm -f "$PROMPT_FILE" "$SYS_FILE"' EXIT INT TERM

if [ "$#" -gt 0 ]; then
  printf '%s\n' "$*" > "$PROMPT_FILE"
else
  cat > "$PROMPT_FILE"
fi

PEER_ID=""
if [ -n "$DAEMON_ID" ] && [ -n "$SESSION_ID" ]; then
  PEER_ID="mu:$DAEMON_ID:$SESSION_ID"
fi

cat > "$SYS_FILE" <<EOF
You are a spawned worker agent. Execute the user's task and print a concise result.

Worker identity:
- daemon_id: ${DAEMON_ID:-unknown}
- session_id: ${SESSION_ID:-unknown}
- dialogue peer id: ${PEER_ID:-unknown}
- reply_to session: ${REPLY_TO:-unknown}

If mcp-dialogue tools are available, register presence before work by polling your own inbox once (dialogue_poll with a short timeout is enough). Use peer id '${PEER_ID:-unknown}'. For mu-native dialogue_say, the 'from' field is bound automatically by the runtime; do not spoof it. If you need to notify the parent and know its peer id, send a short result there as well as printing stdout. If dialogue tools are unavailable, stdout is the fallback result channel.
EOF

printf '[mu-spawn] provider=%s model=%s role=%s rank=%s session=%s peer=%s\n' \
  "$PROVIDER" "$MODEL" "$ROLE" "$RANK" "${SESSION_ID:-unknown}" "${PEER_ID:-unknown}" >&2

if [ "$DRY_RUN" -eq 1 ]; then
  if [ "$PROVIDER" = claude-oauth ]; then
    printf 'cd %s && timeout %s claude -p --model %s --append-system-prompt-file %s --output-format text < %s\n' \
      "$(q "$CWD")" "$(q "$TIMEOUT_SECS")" "$(q "$MODEL")" "$(q "$SYS_FILE")" "$(q "$PROMPT_FILE")"
  else
    printf 'cd %s && timeout %s %s ask --bare --provider %s --model %s --append-system-prompt %s --prompt-file %s\n' \
      "$(q "$CWD")" "$(q "$TIMEOUT_SECS")" "$(q "$MU_BIN")" "$(q "$PROVIDER")" "$(q "$MODEL")" "$(q "$SYS_FILE")" "$(q "$PROMPT_FILE")"
  fi
  exit 0
fi

cd "$CWD"

if [ "$PROVIDER" = claude-oauth ]; then
  set -- claude -p --model "$MODEL" --append-system-prompt-file "$SYS_FILE" \
    --output-format text --allowedTools Read,Grep,Glob,LS,Bash,Edit,Write \
    --permission-mode bypassPermissions
  [ -z "$MCP_CONFIG" ] || set -- "$@" --mcp-config "$MCP_CONFIG"
  exec timeout "$TIMEOUT_SECS" "$@" < "$PROMPT_FILE"
fi

# For mu providers, keep the worker hermetic but useful. Dialogue tools come
# from the operator's configured MCP servers; built-in tools are granted here.
exec timeout "$TIMEOUT_SECS" "$MU_BIN" ask --bare \
  --provider "$PROVIDER" --model "$MODEL" \
  --append-system-prompt "$SYS_FILE" \
  --tools read,write,edit,glob,grep,ls,bash --bash-yolo --max-turns 40 \
  --prompt-file "$PROMPT_FILE"
